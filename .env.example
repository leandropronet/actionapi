# =============================================================
# Oracle ERP (SiAGRI) — apenas o ETL acessa diretamente
# Schema: SULGOIANO
# Host: 10.62.27.5  Port: 1521  Service: dbtest2
# =============================================================
ORACLE_HOST=10.62.27.5
ORACLE_PORT=1521
ORACLE_SERVICE=dbtest2
ORACLE_SCHEMA=SULGOIANO
ORACLE_USER=
ORACLE_PASS=
ORACLE_POOL_MAX=3

# =============================================================
# PostgreSQL (local Docker)
# =============================================================
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=actionapi
PG_USER=actionapi
PG_PASS=

# =============================================================
# Auth da ActionAPI
# =============================================================
# Lista de API Keys separadas por vírgula
API_KEYS=

# =============================================================
# Carga inicial
# =============================================================
CARGA_INICIAL_ANOS=5

# =============================================================
# Crons ETL (formato cron padrão)
# =============================================================
CRON_ESTOQUE=*/10 * * * *
CRON_PEDIDOS=*/30 * * * *
CRON_FATURAMENTO=0 * * * *
CRON_DUPLICATAS=0 * * * *
CRON_FINANCEIRO=0 * * * *
CRON_CONTABIL=0 1 * * *
CRON_DIMENSOES=0 6 * * *

# =============================================================
# API
# =============================================================
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
