# =============================================================
# Oracle ERP (SiAGRI) — apenas o ETL acessa diretamente
# Schema: SULGOIANO
# Host: 10.62.27.5  Port: 1521  Service: dbtest2
# =============================================================
ORACLE_HOST=10.62.27.5
ORACLE_PORT=1521
ORACLE_SERVICE=dbtest2
ORACLE_SCHEMA=SULGOIANO
ORACLE_USER=
ORACLE_PASS=
ORACLE_POOL_MAX=3

# =============================================================
# PostgreSQL (local Docker)
# =============================================================
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=actionapi
PG_USER=actionapi
PG_PASS=

# =============================================================
# Auth da ActionAPI
# =============================================================
# Lista de API Keys separadas por vírgula
API_KEYS=

# Login do painel e Swagger
ADMIN_USERNAME=admin
# Gere com: cd packages/api && npm run hash-password -- "sua-senha-forte"
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
SESSION_COOKIE_NAME=actionapi_session
SESSION_TTL_SECONDS=28800

# true em produção com HTTPS; false apenas para desenvolvimento HTTP local
COOKIE_SECURE=true
ENFORCE_HTTPS=true
TRUST_PROXY=true

# Limites de proteção
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute
LOGIN_RATE_LIMIT_MAX=10
BODY_LIMIT_BYTES=1048576

# =============================================================
# Carga inicial
# =============================================================
CARGA_INICIAL_ANOS=5

# =============================================================
# Crons ETL (formato cron padrão)
# =============================================================
CRON_ESTOQUE=*/10 * * * *
CRON_PEDIDOS=*/30 * * * *
CRON_FATURAMENTO=0 * * * *
CRON_DUPLICATAS=0 * * * *
CRON_FINANCEIRO=0 * * * *
CRON_RECEBIMENTOS=0 * * * *
CRON_PAGAMENTOS=0 * * * *
CRON_LOTES=0 6 * * *
CRON_SALDO_LOTE=30 6 * * *
CRON_CONTABIL=0 1 * * *
CRON_DIMENSOES=0 6 * * *

# =============================================================
# API
# =============================================================
PORT=3000
BIND_HOST=127.0.0.1
# PostgreSQL fica acessível apenas localmente no host
PG_BIND_HOST=127.0.0.1
PG_EXPOSE_PORT=5432
NODE_ENV=production
LOG_LEVEL=info
